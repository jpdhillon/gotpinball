<% layout('layouts/boilerplate') -%> 

<div class="card mt-5" style="width: 60rem;">
  <div class="card-body"> 
    <h5 class="card-title"><b>Name:</b> <%= location.name %></h5>
    <p class="card-text"><b>Address:</b> <%= location.street %><br><%= location.city + ", " + location.state + " " + location.zip + " " + location.country %></p>
    <p class="card-text"><b>Phone:</b> <%= location.phone %></p>
    <p class="card-text"><b>Website:</b> <a href="<%= location.website %>"><%= location.website %></a></p>
  </div>
</div>

<div class="card" style="width: 60rem;">
  <div class="card-header">
    Pinball Machines at this location:
  </div>
  <ul class="list-group list-group-flush">
    <% for (i=0; i < locationMachines.length; i++) {%> 
      <li class="list-group-item"><b>Name:</b> <%= locationMachines[i].name %><br>Manufactured by <%= locationMachines[i].manufacturer %> in <%= locationMachines[i].year %>.<br><b>Internet Pinball Database Link:</b> <a href="<%= locationMachines[i].ipdb_link %>"><%= locationMachines[i].ipdb_link %></a><br><br><img src="<%= locationMachines[i].opdb_img %>" alt=""></li>
    <% } %> 
  </ul>
</div>

<div>
  <h2>Leave a Review</h2>
  <form action="/location/<%=location.id%>/reviews" method="POST" class="mb-3 validated-form" novalidate>
    <input class="form-control d-none" type="number" value="<%=location.id%>" name="review[locationId]" readonly>
    <div class="mb-3">
        <label class="form-label" for="rating">Rating</label>
        <input class="form-range" type="range" min="1" max="5" name="review[rating]" id="rating">
    </div>
    <div class="mb-3">
        <label class="form-label" for="body">Review</label>
        <textarea class="form-control" name="review[body]" id="body" cols="30" rows="3" required></textarea>
        <div class="valid-feedback">
            Looks good!
        </div>
    </div>
    <button class="btn btn-success">Submit</button>
  </form>
</div>

<% console.log(reviews) %> 
<% for(let review of reviews) { %>
  <div class="mb-3">
    <p>Rating: <%= review.rating %>
    </p>
    <p>Review: <%= review.body %>
    </p>
  </div>
  <% } %>
