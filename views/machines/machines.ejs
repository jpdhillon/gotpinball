<% layout('layouts/boilerplate') -%> 

  <h1 class="mx-3">Find Your Favorite Pinball Machine!</h1>
  <h2 class="mx-3"><i>(150 Machines Listed Per Page, sorted alphabetically)</i></h2>

  <div class="row bg-secondary bg-opacity-10 mx-3 my-3">
    <% for (i=0; i < machines.length; i++) {%> 
      <div class="col-xs-12 col-sm-12 col-md-6 col-xl-4 col-xxl-3">
        <div class="card mx-3 my-3" style="width: 18rem;">
          <img src="<%= machines[i].opdb_img %>" class="card-img-top" alt="">
          <div class="card-body"> 
            <p class="card-text">
              <b>Name:</b> <%= machines[i].name %><br>Manufactured by <%= machines[i].manufacturer %> in <%= machines[i].year %>.<br><b>Internet Pinball Database Link:</b> <a href="<%= machines[i].ipdb_link %>"><%= machines[i].ipdb_link %></a>
            </p>
          </div>
        </div>
      </div>
    <% } %> 
  </div>

  <nav aria-label="Page navigation example">
    <ul class="pagination">
      <li class="page-item"><a class="page-link" href="#">Previous</a></li>
      <li class="page-item"><a class="page-link" href="#">1</a></li>
      <li class="page-item"><a class="page-link" href="#">2</a></li>
      <li class="page-item"><a class="page-link" href="#">3</a></li>
      <li class="page-item"><a class="page-link" href="#">4</a></li>
      <li class="page-item"><a class="page-link" href="#">5</a></li>
      <li class="page-item"><a class="page-link" href="#">6</a></li>
      <li class="page-item"><a class="page-link" href="#">7</a></li>
      <li class="page-item"><a class="page-link" href="#">8</a></li>
      <li class="page-item"><a class="page-link" href="#">9</a></li>
      <li class="page-item"><a class="page-link" href="#">Next</a></li>
    </ul>
  </nav>
