<% layout('layouts/boilerplate') -%> 

  <% if (machineLocations.length !== 0) { %>
    <Div class="row bg-secondary bg-opacity-10 justify-content-evenly px-2">
      <h1 class="px-3">You can find this machine at the following locations!</h1>
      <% for (i=0; i < machineLocations.length; i++) {%> 
      <div class="card card col-xs-12 col-sm-12 col-md-3 text-center m-3" style="width: 18rem;">
        <div class="card-body"> 
          <% const id = machineLocations[i].id %> 
          <a href="/location/<%=id%>" class="card-link" > <%= machineLocations[i].name %> </a>
          <p><%= machineLocations[i].city + ', ' + machineLocations[i].state %> </p>
        </div>
      </div>
      <% } %>
    </Div>
  <% } else { %>
    <h1>Sorry, We Have No Locations for This Machine</h2>
  <% } %>

  